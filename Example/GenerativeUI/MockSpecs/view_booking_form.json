{
  "schemaVersion": "0.1",
  "screen": {
    "id": "booking_form",
    "title": "补充预订信息",
    "state": {
      "name": "",
      "phone": ""
    },
    "components": [
      {
        "id": "intro_section",
        "type": "section",
        "props": {
          "title": "说明"
        },
        "children": [
          {
            "id": "intro_text",
            "type": "text",
            "props": {
              "text": "请填写联系人信息，以便我们为您确认预订。",
              "style": "body"
            }
          }
        ]
      },
      {
        "id": "name_input",
        "type": "textInput",
        "props": {
          "label": "姓名",
          "binding": "name",
          "placeholder": "请输入您的姓名"
        }
      },
      {
        "id": "phone_input",
        "type": "textInput",
        "props": {
          "label": "手机号",
          "binding": "phone",
          "placeholder": "请输入手机号",
          "keyboardType": "phone"
        }
      },
      {
        "id": "submit_btn",
        "type": "button",
        "props": {
          "label": "提交",
          "style": "primary"
        },
        "action": {
          "id": "booking.submit"
        }
      }
    ]
  }
}
